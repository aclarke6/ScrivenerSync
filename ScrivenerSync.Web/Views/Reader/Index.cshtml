@model TopLevelViewModel
@{ ViewData["Title"] = Model.ProjectName; }

<h2>@Model.ProjectName</h2>

@if (!Model.TopLevelSections.Any())
{
    <p>No content is available to read yet.</p>
}
else
{
    <ul style="list-style: none; padding: 0; margin-top: 24px;">
        @foreach (var s in Model.TopLevelSections)
        {
            <li style="margin-bottom: 16px;">
                <a asp-action="Browse" asp-route-id="@s.Id"
                   style="font-size: 1.2em; font-weight: bold;">@s.Title</a>
            </li>
        }
    </ul>
}
