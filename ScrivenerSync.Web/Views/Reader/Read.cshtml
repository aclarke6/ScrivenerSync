@model ChapterReadViewModel
@{ ViewData["Title"] = Model.Chapter.Title; }

<style>
    .chapter-layout { display: flex; gap: 32px; }
    .chapter-sidebar { width: 200px; flex-shrink: 0; position: sticky; top: 20px; }
    .chapter-main { flex: 1; min-width: 0; }
    .scene-block { display: flex; gap: 24px; margin-bottom: 48px; }
    .scene-prose { flex: 1; min-width: 0; }
    .scene-comments { width: 280px; flex-shrink: 0; }
    .scene-prose-content * { font-family: Georgia, serif !important; font-size: 16px !important; }
    .comment-box { border-left: 3px solid #2a6496; padding: 10px 12px; margin-bottom: 10px;
                   background: white; font-size: 0.85em; }
    .comment-box.private { border-left-color: #f0ad4e; }
    .add-comment-mini textarea { width: 100%; padding: 6px; font-size: 0.8em;
                                  font-family: Georgia, serif; box-sizing: border-box; }
    .chapter-comments { margin-top: 48px; padding-top: 32px;
                        border-top: 2px solid #eee; }
    .btn-xs { padding: 3px 8px; font-size: 11px; }
    @@media (max-width: 900px) {
        .scene-block { flex-direction: column; }
        .scene-comments { width: 100%; }
    }
</style>

<div class="chapter-layout">

    <!-- Sidebar TOC -->
    <aside class="chapter-sidebar">
        @if (Model.BookContents is not null)
        {
            <div style="margin-bottom:10px;">
                <a asp-action="Index" style="font-size:0.8em; color:#888;">@Model.ProjectName</a>
                <span style="color:#ccc; margin:0 4px;">&rsaquo;</span>
                <a asp-action="Browse" asp-route-id="@Model.BookContents.TopLevelSection.Id"
                   style="font-size:0.8em; color:#888;">@Model.BookContents.TopLevelSection.Title</a>
            </div>
            @foreach (var group in Model.BookContents.Groups)
            {
                @if (!string.IsNullOrEmpty(group.Heading))
                {
                    <div style="font-size:0.75em; font-weight:bold; color:#555;
                                text-transform:uppercase; letter-spacing:0.03em;
                                margin:12px 0 4px 0;">@group.Heading</div>
                }
                @foreach (var sub in group.SubGroups)
                {
                    <div style="font-size:0.75em; color:#888; margin:8px 0 3px 8px;">@sub.Heading</div>
                    @if (sub.ChapterSection is not null)
                    {
                        <a asp-action="Read" asp-route-id="@sub.ChapterSection.Id"
                           style="display:block; font-size:0.85em; padding-left:16px; margin-bottom:3px;
                                  font-weight:@(sub.ChapterSection.Id == Model.Chapter.Id ? "bold" : "normal");
                                  color:@(sub.ChapterSection.Id == Model.Chapter.Id ? "#1a1a1a" : "#2a6496");">
                            @sub.ChapterSection.Title
                        </a>
                    }
                }
                @if (group.ChapterSection is not null)
                {
                    <a asp-action="Read" asp-route-id="@group.ChapterSection.Id"
                       style="display:block; font-size:0.85em; margin-bottom:4px;
                              font-weight:@(group.ChapterSection.Id == Model.Chapter.Id ? "bold" : "normal");
                              color:@(group.ChapterSection.Id == Model.Chapter.Id ? "#1a1a1a" : "#2a6496");">
                        @group.ChapterSection.Title
                    </a>
                }
            }
        }
    </aside>

    <!-- Main content -->
    <main class="chapter-main">

        <!-- Breadcrumb -->
        @if (Model.Breadcrumb.Any())
        {
            <div style="font-size:0.8em; color:#888; margin-bottom:6px;">
                @for (int i = 0; i < Model.Breadcrumb.Count; i++)
                {
                    @Model.Breadcrumb[i]
                    if (i < Model.Breadcrumb.Count - 1)
                    { <span style="margin:0 6px;">&rsaquo;</span> }
                }
            </div>
        }

        <h2 style="margin-top:0;">@Model.Chapter.Title</h2>

        <!-- Scenes with side comments -->
        @foreach (var item in Model.Scenes)
        {
            <div class="scene-block">

                <!-- Prose -->
                <div class="scene-prose">
                    <h4 style="color:#666; font-weight:normal; font-size:0.9em;
                                border-bottom:1px solid #eee; padding-bottom:4px;
                                margin-bottom:16px;">@item.Scene.Title</h4>
                    <div style="background:white; padding:24px 28px; border:1px solid #eee;
                                line-height:1.8;">
                        <div class="scene-prose-content">
                            @Html.Raw(item.Scene.HtmlContent ?? "<p><em>No content.</em></p>")
                        </div>
                    </div>
                </div>

                <!-- Scene comments sidebar -->
                <div class="scene-comments">
                    <div style="font-size:0.75em; text-transform:uppercase; letter-spacing:0.05em;
                                color:#888; margin-bottom:8px;">Comments</div>

                    @foreach (var c in item.Comments)
                    {
                        <div class="comment-box @(c.Visibility == Visibility.Private ? "private" : "")">
                            @if (c.IsSoftDeleted)
                            {
                                <p style="color:#aaa; font-style:italic; margin:0;">Removed.</p>
                            }
                            else
                            {
                                <div style="color:#888; margin-bottom:4px;">
                                    @c.CreatedAt.ToString("dd MMM")
                                    @if (c.Visibility == Visibility.Private)
                                    { <span style="color:#f0ad4e;">[Private]</span> }
                                </div>
                                <p style="margin:0 0 6px 0;">@c.Body</p>
                                <form asp-action="AddComment" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="SectionId" value="@item.Scene.Id" />
                                    <input type="hidden" name="ParentCommentId" value="@c.Id" />
                                    <input type="text" name="Body" placeholder="Reply..."
                                           style="width:100%; padding:3px 6px; font-size:0.8em;" />
                                    <button type="submit" class="btn btn-xs"
                                            style="margin-top:4px;">Reply</button>
                                </form>
                            }
                        </div>
                    }

                    <!-- Add scene comment -->
                    <div class="add-comment-mini" style="margin-top:8px;">
                        <form asp-action="AddComment" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="SectionId" value="@item.Scene.Id" />
                            <textarea name="Body" rows="3"
                                      placeholder="Comment on @item.Scene.Title..."></textarea>
                            <div style="margin-top:4px; display:flex; gap:8px; align-items:center;">
                                <label style="font-size:0.75em;">
                                    <input type="checkbox" name="IsPrivate" /> Private
                                </label>
                                <button type="submit" class="btn btn-xs">Post</button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        }

        <!-- Chapter-level comments -->
        <div class="chapter-comments">
            <h3>Chapter Comments</h3>
            <p style="font-size:0.85em; color:#888;">
                Use chapter comments for overall impressions of the chapter as a whole.
            </p>

            @foreach (var c in Model.ChapterComments)
            {
                <div style="border-left:3px solid @(c.Visibility == Visibility.Private ? "#f0ad4e" : "#2a6496");
                            padding:12px 16px; margin-bottom:14px; background:white;">
                    @if (c.IsSoftDeleted)
                    {
                        <p style="color:#888; font-style:italic; margin:0;">This comment has been removed.</p>
                    }
                    else
                    {
                        <div style="margin-bottom:6px;">
                            <span style="font-size:0.85em; color:#888;">@c.CreatedAt.ToString("dd MMM yyyy")</span>
                            @if (c.Visibility == Visibility.Private)
                            { <span style="color:#f0ad4e; font-size:0.75em; margin-left:6px;">[Private]</span> }
                        </div>
                        <p style="margin:0 0 8px 0;">@c.Body</p>
                        <form asp-action="AddComment" method="post" style="display:flex; gap:8px;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="SectionId" value="@Model.Chapter.Id" />
                            <input type="hidden" name="ParentCommentId" value="@c.Id" />
                            <input type="text" name="Body" placeholder="Reply..."
                                   style="flex:1; padding:5px 8px; font-size:0.85em;" />
                            <button type="submit" class="btn btn-sm">Reply</button>
                        </form>
                    }
                </div>
            }

            <div style="background:#f8f8f6; padding:20px; border:1px solid #eee; margin-top:16px;">
                <h4 style="margin-top:0;">Add a chapter comment</h4>
                <form asp-action="AddComment" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="SectionId" value="@Model.Chapter.Id" />
                    <textarea name="Body" rows="4" placeholder="Your overall thoughts on this chapter..."
                              style="width:100%; padding:10px; font-family:Georgia,serif;
                                     font-size:15px; box-sizing:border-box;"></textarea>
                    <div style="margin-top:10px; display:flex; gap:20px; align-items:center;">
                        <label style="font-size:0.85em;">
                            <input type="checkbox" name="IsPrivate" />
                            Private - only you and the author can see this
                        </label>
                        <button type="submit" class="btn">Post Comment</button>
                    </div>
                </form>
            </div>
        </div>

    </main>
</div>
