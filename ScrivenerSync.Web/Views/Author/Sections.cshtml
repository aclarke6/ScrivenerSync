@model IReadOnlyList<(ScrivenerSync.Domain.Entities.Section Section, int Depth)>
@{
    ViewData["Title"] = "Sections";
    var project     = ViewBag.Project as ScrivenerSync.Domain.Entities.ScrivenerProject;
    var publishable = ViewBag.Publishable as HashSet<Guid> ?? new HashSet<Guid>();
}

<h2>@project?.Name - Sections</h2>
<p><a asp-action="Dashboard">&larr; Back to Dashboard</a></p>
<p style="font-size:0.85em; color:#666;">
    Publish buttons appear on chapters where all scenes are First Draft or above.
</p>

@if (!Model.Any())
{
    <p>No sections found. Try syncing the project first.</p>
}
else
{
    <table>
        <tr>
            <th>Title</th>
            <th>Type</th>
            <th>Status</th>
            <th>Published</th>
            <th>Actions</th>
        </tr>
        @foreach (var item in Model)
        {
            var s      = item.Section;
            var indent = item.Depth * 20;
            var isFolder = s.NodeType == NodeType.Folder;
            <tr style="@(isFolder ? "background:#f5f5f0;" : "")">
                <td style="padding-left: @(8 + indent)px; font-weight: @(isFolder ? "bold" : "normal")">
                    @if (!isFolder)
                    {
                        <a asp-action="Section" asp-route-id="@s.Id">@s.Title</a>
                    }
                    else
                    {
                        @s.Title
                    }
                </td>
                <td style="color:#888; font-size:0.85em">@s.NodeType</td>
                <td>@(s.ScrivenerStatus ?? "-")</td>
                <td>
                    @if (s.IsPublished)
                    {
                        <span style="color:#27ae60">Published</span>
                    }
                    else
                    {
                        <span style="color:#888">-</span>
                    }
                </td>
                <td>
                    @if (isFolder)
                    {
                        if (s.IsPublished)
                        {
                            <form asp-action="UnpublishChapter" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="chapterId" value="@s.Id" />
                                <input type="hidden" name="projectId" value="@project!.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Unpublish</button>
                            </form>
                        }
                        else if (publishable.Contains(s.Id))
                        {
                            <form asp-action="PublishChapter" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="chapterId" value="@s.Id" />
                                <input type="hidden" name="projectId" value="@project!.Id" />
                                <button type="submit" class="btn btn-sm">Publish</button>
                            </form>
                        }
                        else
                        {
                            <span style="color:#bbb; font-size:0.8em">Not ready</span>
                        }
                    }
                </td>
            </tr>
        }
    </table>
}
